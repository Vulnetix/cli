_pattern := `(?i)mapquest[a-z0-9_]*(?:api[_-]?key|apikey|consumer[_-]?key|key)[a-z0-9_]*\s*[:=]\s*['"]?([A-Za-z0-9]{32})['"]?`
_keywords := ["mapquest"]

findings contains finding if {
	some path in object.keys(input.file_contents)
	not secrets.skip_path(path)
	lines := split(input.file_contents[path], "\n")
	some i, line in lines
	secrets.has_keyword(line, _keywords)
	m := regex.find_all_string_submatch_n(_pattern, line, 1)
	count(m) > 0
	token := m[0][1]
	not secrets.is_example_token(token)
	secrets.high_entropy(token, 3.8)
	finding := {
		"rule_id": metadata.id,
		"message": "MapQuest API key found; revoke it in the MapQuest Developer dashboard under Manage Keys",
