_pattern := `(?i)(?:p12|pkcs12|pfx)[_-]?(?:password|passphrase|pass)\s*[:=]\s*["']?([^\s"']{8,})["']?`
_keywords := ["p12", "pkcs12", "pfx", "keystore"]

findings contains finding if {
