_pattern := `(?i)https?:\/\/[0-9]+:([^@\s'"]{8,})@[A-Za-z0-9_.:-]+\/api\/(?:prom\/push|v1\/(?:write|push))`
_keywords := ["/api/prom/push", "/api/v1/write"]

findings contains finding if {
