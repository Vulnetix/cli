_pattern := `(?i)wordpress[._-]?com[a-z0-9_]*(?:access[_-]?token|token)\s*[:=]\s*['"]?([A-Za-z0-9%#&^_\-]{40,80})['"]?`
_keywords := ["wordpress.com", "token"]

findings contains finding if {
	some path in object.keys(input.file_contents)
	not secrets.skip_path(path)
	lines := split(input.file_contents[path], "\n")
	some i, line in lines
	secrets.has_keyword(line, _keywords)
	m := regex.find_all_string_submatch_n(_pattern, line, 1)
	count(m) > 0
	token := m[0][1]
	not secrets.is_example_token(token)
	secrets.high_entropy(token, 4)
	finding := {
		"rule_id": metadata.id,
		"message": "WordPress.com access token found; revoke the application in the WordPress.com Apps settings",
