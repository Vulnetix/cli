_pattern := `(?i)nft[._-]?storage[a-z0-9_]*(?:api[_-]?key|token|key)\s*[:=]\s*['"]?(eyJ[A-Za-z0-9_-]{10,}\.eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,})['"]?`
